[user]
    name = YOUR_NAME
    email = YOUR_EMAIL

[commit]
    gpgsign = false

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = Monokai Extended

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = default
