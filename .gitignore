# Lock-файлы
.config/nvim/nvim-pack-lock.json
Brewfile.lock.json

# Бэкапы
*.bak
*_bak

# Логи/runtime
*.log
*.pid
*.sock
__pycache__/
*.pyc

# ОС
.DS_Store

# Tmux runtime/vendor state
.config/tmux/plugins/
tmux-client-*.log
tmux-server-*.log

# Локальные настройки Claude
.claude/settings.local.json
.config/.claude/settings.local.json

# Персональный gitconfig (используй .gitconfig.template)
.gitconfig

# Fish local/universal state
.config/fish/fish_variables

# GitHub CLI auth hosts contain tokens
.config/gh/hosts.yml

# App-local secrets/runtime state
.config/band-tui/
.config/mmux/
.config/rdr/
.config/sshm/config.json
.config/sshm/*history*
.config/sshm/backups/
.config/sshm/*.backup
.config/talos/

# Generated/local dependency state
.config/opencode/node_modules/
.config/opencode/package-lock.json
.config/opencode/bun.lock

# Generic env/credential files
.env
.env.*
*.pem
*.key
*token*
*credentials*
client_secret*.json
client_secrets*.json

# Pi runtime/secrets (в repo хранится только pi/agent non-secret template/assets)
pi/agent/auth.json
pi/agent/sessions/
pi/agent/run-history.jsonl
pi/youtube_credentials/
