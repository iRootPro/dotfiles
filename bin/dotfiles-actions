#!/usr/bin/env bash
# dotfiles:summary=List command palette actions
# dotfiles:args=[--json|--markdown|--check]
# dotfiles:examples=dotfiles actions | dotfiles actions --json | dotfiles actions --check

set -euo pipefail

SOURCE="$(realpath "${BASH_SOURCE[0]}")"
ROOT="$(cd "$(dirname "$SOURCE")/.." && pwd)"
DOTFILES="$ROOT/bin/dotfiles"
SEP=$'\034'

usage() {
  cat <<'EOF'
Usage: dotfiles actions [--json|--markdown|--check]

List command palette actions from tmux helpers, dotfiles commands, and open targets.

Options:
  --json      Emit machine-readable JSON (requires jq)
  --markdown  Emit a Markdown table
  --check     Validate action metadata and source catalogs
EOF
}

static_records() {
  printf '%s%s%s%s%s%s%s\n' 'close' "$SEP" 'base' "$SEP" 'Close palette' "$SEP" 'Exit without running anything'
  printf '%s%s%s%s%s%s%s\n' 'sessions' "$SEP" 'base' "$SEP" 'Sessions switch/create' "$SEP" 'Open sesh picker'
  printf '%s%s%s%s%s%s%s\n' 'windows' "$SEP" 'base' "$SEP" 'Windows switch/close' "$SEP" 'Open tmux window picker'
  printf '%s%s%s%s%s%s%s\n' 'new-session' "$SEP" 'base' "$SEP" 'New tmux session' "$SEP" 'Prompt for session name in current directory'
  printf '%s%s%s%s%s%s%s\n' 'new-window' "$SEP" 'base' "$SEP" 'New tmux window' "$SEP" 'Create window in current directory'
  printf '%s%s%s%s%s%s%s\n' 'smart-close' "$SEP" 'base' "$SEP" 'Smart close' "$SEP" 'Close pane, window, or session safely'
  printf '%s%s%s%s%s%s%s\n' 'split-down' "$SEP" 'base' "$SEP" 'Split down' "$SEP" 'Create horizontal split below'
  printf '%s%s%s%s%s%s%s\n' 'split-right' "$SEP" 'base' "$SEP" 'Split right' "$SEP" 'Create vertical split on the right'
  printf '%s%s%s%s%s%s%s\n' 'opencode-launch' "$SEP" 'base' "$SEP" 'Opencode launch' "$SEP" 'Start opencode session for current directory'
  printf '%s%s%s%s%s%s%s\n' 'opencode-list' "$SEP" 'base' "$SEP" 'Opencode list' "$SEP" 'Show opencode sessions'
  printf '%s%s%s%s%s%s%s\n' 'lazygit' "$SEP" 'base' "$SEP" 'Git lazygit' "$SEP" 'Open lazygit in a new window'
  printf '%s%s%s%s%s%s%s\n' 'rename-window' "$SEP" 'base' "$SEP" 'Rename window' "$SEP" 'Prompt for current window name'
  printf '%s%s%s%s%s%s%s\n' 'rename-session' "$SEP" 'base' "$SEP" 'Rename session' "$SEP" 'Prompt for current session name'
}

open_records() {
  command -v jq >/dev/null 2>&1 || return 0
  "$DOTFILES" open --json 2>/dev/null | jq -r --arg sep "$SEP" '
    .targets[]
    | select(.type == "file" or .type == "doc")
    | "open:" + .id + $sep + "open" + $sep + "Open " + .id + $sep + .path + " - " + .summary
  ' 2>/dev/null || true
}

dot_records() {
  command -v jq >/dev/null 2>&1 || return 0
  "$DOTFILES" commands --json 2>/dev/null | jq -r --arg sep "$SEP" '
    .commands[]
    | select(.route != "dotfiles install")
    | select(.route != "dotfiles pi backup")
    | select(.route != "dotfiles pi restore")
    | select(.route != "dotfiles tmux reload")
    | select(.route != "dotfiles actions")
    | if .route == "dotfiles apps" then
        "dot:apps" + $sep + "dotfiles" + $sep + "Apps" + $sep + "Show curated app and CLI catalog",
        "dot:apps%20--missing" + $sep + "dotfiles" + $sep + "Missing apps" + $sep + "Show missing apps/tools",
        "dot:apps%20--check" + $sep + "dotfiles" + $sep + "Apps check" + $sep + "Validate app catalog"
      elif .route == "dotfiles doctor" then
        "dot:doctor" + $sep + "dotfiles" + $sep + "doctor" + $sep + .summary,
        "dot:doctor%20--summary" + $sep + "dotfiles" + $sep + "Doctor summary" + $sep + "Show compact health status"
      elif .route == "dotfiles cleanup" then
        "dot:cleanup" + $sep + "dotfiles" + $sep + "Cleanup audit" + $sep + "Show audit-only cleanup suggestions"
      elif .route == "dotfiles pi status" then
        "dot:pi%20status" + $sep + "dotfiles" + $sep + "Pi status" + $sep + "Show non-secret Pi config status"
      elif .route == "dotfiles status" then
        "dot:status" + $sep + "dotfiles" + $sep + "Repo status" + $sep + "Show repo status and recent commits"
      elif .route == "dotfiles debug" then
        "dot:debug" + $sep + "dotfiles" + $sep + "Debug snapshot" + $sep + "Print safe diagnostic snapshot"
      elif .route == "dotfiles reload" then
        "dot:reload" + $sep + "dotfiles" + $sep + "Reload config" + $sep + "Reload shell/tmux config"
      elif .route == "dotfiles open" then
        "dot:open" + $sep + "dotfiles" + $sep + "Open targets" + $sep + "List curated dotfiles files and docs"
      elif .route == "dotfiles update" then
        "dot:update" + $sep + "dotfiles" + $sep + "Update" + $sep + "Update plugins/tools with the default mode",
        "dot:update%20packages" + $sep + "dotfiles" + $sep + "Update packages" + $sep + "Run Homebrew package updates",
        "dot:update%20plugins" + $sep + "dotfiles" + $sep + "Update plugins" + $sep + "Update shell/editor/tmux plugins",
        "dot:update%20nvim" + $sep + "dotfiles" + $sep + "Update Neovim" + $sep + "Update Neovim plugins",
        "dot:update%20tmux" + $sep + "dotfiles" + $sep + "Update tmux" + $sep + "Update tmux plugins",
        "dot:update%20go" + $sep + "dotfiles" + $sep + "Update Go tools" + $sep + "Update Go-based tools",
        "dot:update%20all" + $sep + "dotfiles" + $sep + "Update all" + $sep + "Run all update modes"
      else
        (.route | sub("^dotfiles "; "")) as $short
        | "dot:" + ($short | gsub(" "; "%20")) + $sep + "dotfiles" + $sep + $short + $sep + (if .route == "dotfiles reload" then "Reload shell/tmux config" else .summary end)
      end
  ' 2>/dev/null || true
}

records() {
  static_records
  open_records
  dot_records
}

show_table() {
  local id kind label summary

  printf '%-24s  %-8s  %-24s  %s\n' 'Action' 'Kind' 'Label' 'Summary'
  printf '%-24s  %-8s  %-24s  %s\n' '------' '----' '-----' '-------'
  while IFS="$SEP" read -r id kind label summary; do
    [ -n "${id:-}" ] || continue
    printf '%-24s  %-8s  %-24s  %s\n' "$id" "$kind" "$label" "$summary"
  done < <(records)
}

show_markdown() {
  local id kind label summary

  echo '| Action | Kind | Label | Summary |'
  echo '| --- | --- | --- | --- |'
  while IFS="$SEP" read -r id kind label summary; do
    [ -n "${id:-}" ] || continue
    printf '| `%s` | `%s` | %s | %s |\n' "$id" "$kind" "${label//|/\\|}" "${summary//|/\\|}"
  done < <(records)
}

show_json() {
  if ! command -v jq >/dev/null 2>&1; then
    echo "jq not found; cannot emit JSON" >&2
    return 1
  fi

  records | jq -Rn '
    [inputs | split("\u001c") | {
      id: .[0],
      kind: .[1],
      label: .[2],
      summary: .[3]
    }] | {ok: true, actions: .}'
}

check_actions() {
  local failures=0 id kind label summary dup

  "$DOTFILES" commands --check >/dev/null || failures=$((failures + 1))
  "$DOTFILES" open --check >/dev/null || failures=$((failures + 1))

  while IFS="$SEP" read -r id kind label summary; do
    if [ -z "${id:-}" ] || [ -z "${kind:-}" ] || [ -z "${label:-}" ] || [ -z "${summary:-}" ]; then
      echo "Invalid action record: $id" >&2
      failures=$((failures + 1))
      continue
    fi

    case "$kind" in base|dotfiles|open) ;; *) echo "Unknown action kind for $id: $kind" >&2; failures=$((failures + 1)) ;; esac
  done < <(records)

  dup="$(records | cut -d "$SEP" -f1 | sort | uniq -d)"
  if [ -n "$dup" ]; then
    while IFS= read -r id; do
      [ -n "$id" ] || continue
      echo "Duplicate action id: $id" >&2
      failures=$((failures + 1))
    done <<<"$dup"
  fi

  if [ "$failures" -gt 0 ]; then
    echo "Actions check failed ($failures issues)" >&2
    return 1
  fi

  echo "Actions check passed"
}

main() {
  local mode="table"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) mode="json" ;;
      --markdown) mode="markdown" ;;
      --check) mode="check" ;;
      -h|--help) usage; return 0 ;;
      *) echo "Unknown option for dotfiles actions: $1" >&2; usage >&2; return 2 ;;
    esac
    shift
  done

  case "$mode" in
    table) show_table ;;
    markdown) show_markdown ;;
    json) show_json ;;
    check) check_actions ;;
  esac
}

main "$@"
